FOOD_QR_API_KEY=your_food_qr_api_key_here
FOOD_NUTRITION_API_KEY=optional_or_unused

# GEMINI_API_KEY: 현재 코드에서 사용되지 않음 (미구현).
# 판정 로직은 규칙 엔진(judge_food_rules/apply_safety_guard)이 전담하며,
# AI는 의존하지 않음. Gemini는 추후 "대안 메뉴 추천에 자연어 설명을
# 덧붙이는" 표현 보조 용도로만 도입 예정 (예: 키워드 기반 대안 메뉴를
# 사람이 읽기 좋은 문장으로 풀어주는 역할). 판정 자체는 위임하지 않음.
GEMINI_API_KEY=not_yet_implemented_planned_for_alternative_food_explanation_text